            <macro guid="226423f3-a894-4097-b333-368474cea3bb" modified="True">
              <button_text>Macro 03</button_text>
              <menu_text>Macro 03</menu_text>
              <help_text>Macro 03</help_text>
              <tooltip>Macro 03</tooltip>
              <script>! -_RunPythonScript (
import rhinoscriptsyntax as rs
import Rhino
import scriptcontext as sc
import Rhino.UI
import Eto.Forms as forms
import Eto.Drawing as drawing

class TextPreviewDialog(forms.Dialog[bool]):
    def __init__(self, xform, options):
        self.Title = "Text Preview"
        self.Padding = drawing.Padding(10)
        self.Resizable = False
        self.Width = 250
        self.xform = xform
        self.options = options
        self.temp_ids = []
        self.combo = forms.DropDown()
        self.combo.DataStore = self.options
        self.combo.SelectedIndex = 0 
        self.combo.SelectedIndexChanged += self.OnTypeChanged
        self.btn_ok = forms.Button(Text = "OK")
        self.btn_ok.Click += self.OnOKButton
        self.btn_cancel = forms.Button(Text = "Cancel")
        self.btn_cancel.Click += self.OnCloseButton
        layout = forms.DynamicLayout()
        layout.Spacing = drawing.Size(5, 5)
        layout.AddRow(forms.Label(Text="Select Text:"))
        layout.AddRow(self.combo)
        layout.AddRow(None)
        layout.AddRow(self.btn_ok, self.btn_cancel)
        self.Content = layout
        self.UpdatePreview()

    def OnTypeChanged(self, sender, e):
        self.UpdatePreview()

    def UpdatePreview(self):
        if self.temp_ids:
            rs.DeleteObjects(self.temp_ids)
            self.temp_ids = []
        text_str = self.options[self.combo.SelectedIndex]
        ids = rs.AddTextObject(text_str, (0,0,0), 10, "Arial", font_style=1)
        if ids:
            bbox = rs.BoundingBox(ids)
            if bbox:
                center = (bbox[0] + bbox[6]) / 2
                move_vec = rs.coerce3dpoint([0,0,0]) - center
                rs.MoveObjects(ids, move_vec)
            rs.TransformObjects(ids, self.xform)
            self.temp_ids = ids
            rs.SelectObjects(ids)
        sc.doc.Views.Redraw()

    def OnOKButton(self, sender, e):
        if self.temp_ids:
            rs.UnselectObjects(self.temp_ids)
        self.Close(True)

    def OnCloseButton(self, sender, e):
        if self.temp_ids:
            rs.DeleteObjects(self.temp_ids)
        self.Close(False)

def run_text_test():
    target_crv = rs.GetObject("Select Rectangle", rs.filter.curve)
    if not target_crv: return
    target_plane = rs.CurvePlane(target_crv)
    mp = rs.CurveAreaCentroid(target_crv)
    if mp: target_plane.Origin = mp[0]
    source_plane = rs.WorldXYPlane()
    xform = Rhino.Geometry.Transform.PlaneToPlane(source_plane, target_plane)
    options = ["A", "B", "C", "TEST"]
    dialog = TextPreviewDialog(xform, options)
    dialog.ShowModal(Rhino.UI.RhinoEtoApp.MainWindow)

if __name__ == "__main__":
    run_text_test()
)</script>
            </macro>
