            <macro guid="6600a258-4fb6-431d-a8ca-a0d484efab8e" modified="True" bitmap_guid="08952c62-15cc-47e9-b60e-bdc50c911daa">
              <text>
                <locale_1033>Copy Array</locale_1033>
              </text>
              <script>-_RunPythonScript (

import rhinoscriptsyntax as rs
import math

OB1 = rs.GetObject( "Select a Object to Array" )
P1 = rs.GetPoint( "Starting Point" )
P2 = rs.GetPoint( "End Point" )
N1 = rs.GetReal( "The Number of the Object" )

V1 = rs.VectorCreate(P2,P1)
V2 = V1/N1
for i in range(1, N1) : rs.CopyObject(OB1,(rs.VectorScale(V2, i)))

)</script>
            </macro>
